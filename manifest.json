{
    "name": "Telegram Blur",
    "description": "Blur private Telegram Web content locally, including chats, messages, media and avatars.",
    "version": "1.0",
    "manifest_version": 3,
    "permissions": ["storage", "tabs"],
    "icons": {
        "16": "icons/icon16.png",
        "32": "icons/icon32.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "action": {
        "default_icon": {
            "16": "icons/icon16.png",
            "32": "icons/icon32.png",
            "48": "icons/icon48.png"
        },
        "default_popup": "popup.html"
    },
    "content_scripts": [
        {
            "run_at": "document_start",
            "matches": ["https://web.telegram.org/*"],
            "js": ["content.js"],
            "css": ["content.css"]
        }
    ]
}
